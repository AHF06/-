.login-page.data-v-e4e4508d {
  min-height: 100vh;
  background: linear-gradient(135deg, #2c5e2a 0%, #4a9e46 50%, #2c5e2a 100%);
  position: relative;
  display: flex;
  flex-direction: column;
  padding-bottom: 40px;
}

/* 背景装饰 */
.bg-decoration.data-v-e4e4508d {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  overflow: hidden;
}
.bg-blur.data-v-e4e4508d {
  position: absolute;
  top: -20%;
  left: -20%;
  width: 140%;
  height: 140%;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.15) 0%, rgba(255, 255, 255, 0) 70%);
}

